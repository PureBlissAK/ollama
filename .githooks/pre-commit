#!/bin/bash
# Pre-commit hook for Ollama Elite AI Platform
# Runs all quality checks before commit
# Usage: This runs automatically on 'git commit'

set -e

echo "🔍 Running pre-commit checks..."
echo ""

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track failures
FAILED=0

# Get the list of staged Python files
PYTHON_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$' || true)

if [ -z "$PYTHON_FILES" ]; then
    echo "ℹ️  No Python files to check"
    exit 0
fi

# 1. Type checking with mypy
echo "📋 Type checking with mypy..."
if ! mypy $PYTHON_FILES --strict 2>&1 | grep -q "error:"; then
    echo -e "${GREEN}✅ Type checking passed${NC}"
else
    echo -e "${RED}❌ Type checking failed${NC}"
    mypy $PYTHON_FILES --strict || true
    FAILED=$((FAILED + 1))
fi

# 2. Linting with ruff
echo ""
echo "🔍 Linting with ruff..."
if ruff check $PYTHON_FILES > /dev/null 2>&1; then
    echo -e "${GREEN}✅ Linting passed${NC}"
else
    echo -e "${RED}❌ Linting found issues${NC}"
    ruff check $PYTHON_FILES || true
    FAILED=$((FAILED + 1))
fi

# 3. Code formatting check (black)
echo ""
echo "💅 Checking code format with black..."
if black --check $PYTHON_FILES > /dev/null 2>&1; then
    echo -e "${GREEN}✅ Code format passed${NC}"
else
    echo -e "${YELLOW}⚠️  Code format issues found - auto-fixing...${NC}"
    black $PYTHON_FILES > /dev/null 2>&1
    echo "Re-staging formatted files..."
    git add $PYTHON_FILES
fi

# 4. Security audit (pip-audit)
echo ""
echo "🔐 Security audit with pip-audit..."
if pip-audit --desc > /dev/null 2>&1; then
    echo -e "${GREEN}✅ Security audit passed${NC}"
else
    echo -e "${YELLOW}⚠️  Security vulnerabilities detected${NC}"
    pip-audit --desc || true
    # Don't fail on audit - let user decide
fi

# 5. Test coverage check
echo ""
echo "🧪 Running tests..."
if pytest tests/unit/ -q --tb=short > /dev/null 2>&1; then
    echo -e "${GREEN}✅ Unit tests passed${NC}"
else
    echo -e "${RED}❌ Unit tests failed${NC}"
    pytest tests/unit/ -q --tb=short || true
    FAILED=$((FAILED + 1))
fi

# Summary
echo ""
echo "════════════════════════════════════════════════════════════"
if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}✅ All pre-commit checks passed!${NC}"
    echo "Proceeding with commit..."
    exit 0
else
    echo -e "${RED}❌ Pre-commit checks failed: $FAILED check(s) failed${NC}"
    echo ""
    echo "To fix issues:"
    echo "  • Run: ruff check --fix <file>"
    echo "  • Run: black <file>"
    echo "  • Run: pytest tests/"
    echo "  • Run: mypy <file> --strict"
    echo ""
    echo "To bypass (not recommended):"
    echo "  git commit --no-verify"
    echo "════════════════════════════════════════════════════════════"
    exit 1
fi
