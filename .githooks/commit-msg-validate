#!/bin/bash
# Commit message validation hook
# Enforces Ollama elite standards for commit messages
# Usage: git commit -m "type(scope): description"

set -e

commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

# Extract first line
first_line=$(echo "$commit_msg" | head -n 1)

# Valid commit types
valid_types=(
    "feat"       # New feature
    "fix"        # Bug fix
    "refactor"   # Code refactoring
    "perf"       # Performance improvement
    "test"       # Test changes
    "docs"       # Documentation
    "infra"      # Infrastructure
    "security"   # Security changes
    "chore"      # Maintenance
)

# Validate commit message format: type(scope): description
if ! [[ $first_line =~ ^([a-z]+)(\([a-z-]+\))?:\ [A-Z].*$ ]]; then
    echo "❌ ERROR: Invalid commit message format"
    echo "Format: type(scope): description"
    echo ""
    echo "Your commit message:"
    echo "  $first_line"
    echo ""
    echo "Example of valid format:"
    echo "  feat(api): add streaming response support"
    echo "  fix(auth): resolve token expiration race condition"
    echo "  refactor(services): split inference into dedicated modules"
    echo ""
    echo "Valid types: ${valid_types[@]}"
    exit 1
fi

# Extract type
type=$(echo "$first_line" | sed -E 's/^([a-z]+).*/\1/')

# Validate type is in allowed list
if [[ ! " ${valid_types[@]} " =~ " ${type} " ]]; then
    echo "❌ ERROR: Invalid commit type '$type'"
    echo "Valid types: ${valid_types[@]}"
    exit 1
fi

# Check subject line length (max 50 characters)
if [ ${#first_line} -gt 50 ]; then
    echo "⚠️  WARNING: First line exceeds 50 characters (${#first_line})"
    echo "  Consider shortening: $first_line"
fi

# Check that there's a blank line after subject (if body exists)
if [ $(wc -l < "$commit_msg_file") -gt 1 ]; then
    second_line=$(sed -n '2p' "$commit_msg_file")
    if [ -n "$second_line" ]; then
        echo "❌ ERROR: Missing blank line between subject and body"
        echo "Add a blank line after the subject line"
        exit 1
    fi
fi

# Check that description starts with capital letter (already validated by regex)
echo "✅ Commit message format valid"
