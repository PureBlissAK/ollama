# Ollama Server Configuration
# Architecture: Ollama runs locally on Docker, GCP LB provides public access
# - Local Docker host: 192.168.168.35:8000
# - GCP Load Balancer: https://elevatediq.ai/ollama (TLS termination at LB)
# - All AI workloads run locally, GCP provides ONLY the Load Balancer

# Local binding (for GCP LB to route to)
OLLAMA_HOST=0.0.0.0:8000
LOCAL_DOCKER_HOST=192.168.168.35

# Public-facing endpoint (via GCP LB)
OLLAMA_PUBLIC_URL=https://elevatediq.ai/ollama
OLLAMA_DOMAIN=elevatediq.ai
OLLAMA_ENABLE_TLS=true

# Model paths and caching
OLLAMA_MODELS_PATH=/models
OLLAMA_CACHE_SIZE=50G
OLLAMA_GPU_MEMORY=24000

# CUDA/GPU Configuration
CUDA_VISIBLE_DEVICES=0  # Comma-separated GPU indices
CUDA_DEVICE_ORDER=PCI_BUS_ID
TORCH_DEVICE_BATCH_SIZE=1

# Database Configuration
DATABASE_URL=postgresql://ollama:changeme@postgres:5432/ollama
DATABASE_POOL_SIZE=20
DATABASE_TIMEOUT=30

# Redis Cache
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=
REDIS_DB=0

# Monitoring & Observability
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
JAEGER_ENABLED=true
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security
API_KEY_AUTH_ENABLED=true
API_KEY_HEADER=X-API-Key
CORS_ORIGINS=["https://elevatediq.ai","https://*.elevatediq.ai","http://localhost:3000","http://localhost:8080"]
CORS_ALLOW_CREDENTIALS=true
CORS_EXPOSE_HEADERS=["Content-Type","X-RateLimit-Limit","X-RateLimit-Remaining"]

# TLS Configuration (handled by GCP LB, supports local termination)
TLS_CERT_PATH=/etc/ssl/certs/elevatediq.ai.crt
TLS_KEY_PATH=/etc/ssl/private/elevatediq.ai.key
TLS_MIN_VERSION=1.2
REQUEST_TIMEOUT=300

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=150

# Model Configuration
MODEL_CACHE_TYPE=redis
MODEL_CONTEXT_LENGTH=4096
ENABLE_MODEL_QUANTIZATION=true
ENABLE_FLASH_ATTENTION=true

# Performance Tuning
MAX_CONCURRENT_REQUESTS=32
REQUEST_QUEUE_SIZE=1000
PREFILL_BATCH_SIZE=16
DECODE_BATCH_SIZE=8
ENABLE_PAGING=true

# Vector Database
VECTOR_DB_TYPE=qdrant
VECTOR_DB_URL=http://qdrant:6333
VECTOR_DB_COLLECTION=embeddings
EMBEDDING_MODEL=all-minilm-l6-v2

# Development/Debug
DEBUG_MODE=false
ENABLE_PROFILING=false
ENABLE_MEMORY_TRACKING=false
