# =============================================================================
# Ollama API Environment Configuration
# =============================================================================
# Architecture: Ollama runs locally on Docker, GCP LB provides public access
# - Local Docker host: 192.168.168.42:8000
# - GCP Load Balancer: https://elevatediq.ai/ollama (TLS termination at LB)
# - All AI workloads run locally, GCP provides ONLY the Load Balancer
#
# Copy this file to .env and update with your production values
# =============================================================================

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Local binding (for GCP LB to route to)
HOST=0.0.0.0
PORT=8000
LOCAL_DOCKER_HOST=192.168.168.42

# Public-facing endpoint (via GCP LB)
PUBLIC_URL=https://elevatediq.ai/ollama
DOMAIN=elevatediq.ai
ENABLE_TLS=true
WORKERS=4
LOG_LEVEL=INFO

# =============================================================================
# OLLAMA ENGINE CONFIGURATION
# =============================================================================
# Ollama server URL (local or remote)
OLLAMA_BASE_URL=http://localhost:11434

# Default model for inference
OLLAMA_DEFAULT_MODEL=llama2

# Timeout settings (seconds)
OLLAMA_REQUEST_TIMEOUT=300
OLLAMA_CONNECT_TIMEOUT=10

# Model paths and caching
OLLAMA_MODELS_PATH=/models
OLLAMA_CACHE_SIZE=50G
OLLAMA_GPU_MEMORY=24000

# CUDA/GPU Configuration
CUDA_VISIBLE_DEVICES=0
CUDA_DEVICE_ORDER=PCI_BUS_ID
TORCH_DEVICE_BATCH_SIZE=1

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection URL (async driver required for FastAPI)
DATABASE_URL=postgresql+asyncpg://ollama:changeme@localhost:5432/ollama

# Connection pool settings
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# Optional Redis password (leave empty for no auth)
REDIS_PASSWORD=

# Redis connection pool settings
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5

# =============================================================================
# VECTOR DATABASE (QDRANT) CONFIGURATION
# =============================================================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# Default collection settings
QDRANT_COLLECTION_NAME=documents
QDRANT_VECTOR_SIZE=384

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
# Prometheus metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Jaeger tracing
JAEGER_ENABLED=false
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
JAEGER_SERVICE_NAME=ollama-api

# Grafana
GRAFANA_URL=http://localhost:3000
GRAFANA_ADMIN_PASSWORD=admin

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=your-secret-key-change-me-in-production

# JWT token expiration (seconds)
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# API Key settings
API_KEY_AUTH_ENABLED=true
API_KEY_HEADER=X-API-Key
API_KEY_PREFIX=ollama_

# Password hashing
BCRYPT_ROUNDS=12

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
CORS_ORIGINS=["https://elevatediq.ai","https://*.elevatediq.ai","http://localhost:3000","http://localhost:8080"]
CORS_ALLOW_CREDENTIALS=true
CORS_EXPOSE_HEADERS=["X-Request-ID","Content-Type"]

# Trusted hosts (for reverse proxy)
TRUSTED_HOSTS=["localhost","127.0.0.1","elevatediq.ai"]

# TLS Configuration (handled by GCP LB, supports local termination)
TLS_CERT_PATH=/etc/ssl/certs/elevatediq.ai.crt
TLS_KEY_PATH=/etc/ssl/private/elevatediq.ai.key
TLS_MIN_VERSION=1.2
REQUEST_TIMEOUT=300

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Rate limit by user
RATE_LIMIT_PER_USER=1000
RATE_LIMIT_PER_USER_PERIOD=3600

# =============================================================================
# CACHING
# =============================================================================
# Response cache TTL (seconds)
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# Model cache settings
MODEL_CACHE_ENABLED=true
MODEL_CACHE_TTL=3600
MODEL_CACHE_TYPE=redis

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================
# Embedding model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# Text chunking for documents
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Model settings
MODEL_CONTEXT_LENGTH=4096
ENABLE_MODEL_QUANTIZATION=true
ENABLE_FLASH_ATTENTION=true

# Performance Tuning
MAX_CONCURRENT_REQUESTS=32
REQUEST_QUEUE_SIZE=1000
PREFILL_BATCH_SIZE=16
DECODE_BATCH_SIZE=8
ENABLE_PAGING=true

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_CHAT=true
ENABLE_EMBEDDINGS=true
ENABLE_RAG=true
ENABLE_USAGE_TRACKING=true
ENABLE_WEBSOCKETS=false

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
DEBUG=false
RELOAD=false
ACCESS_LOG=false

# Testing
TESTING=false
TEST_DATABASE_URL=postgresql+asyncpg://ollama:test@localhost:5432/ollama_test

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================
# SSL/TLS
SSL_ENABLED=false
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# Behind reverse proxy
PROXY_HEADERS=true
FORWARDED_ALLOW_IPS=*

# =============================================================================
# CLOUD PROVIDER SETTINGS (Optional)
# =============================================================================
# GCP
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_STORAGE_BUCKET=

# AWS
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# =============================================================================
# EXTERNAL SERVICES (Optional)
# =============================================================================
# Sentry error tracking
SENTRY_DSN=

# SendGrid email
SENDGRID_API_KEY=

# Slack notifications
SLACK_WEBHOOK_URL=
