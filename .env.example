# =============================================================================
# Ollama Production Environment Variables
# =============================================================================
# CRITICAL: NEVER commit secrets to git
# Copy to .env.prod and fill with actual values (only on production servers)
# All secrets should use GCP Secret Manager in production
# =============================================================================

# ============================================================
# Application Configuration
# ============================================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# ============================================================
# Database Configuration
# ============================================================
# ⚠️  CRITICAL: Load from GCP Secret Manager, never hardcode
DATABASE_URL=postgresql://ollama:CHANGEME@prod-ollama-postgres:5432/ollama
DB_PASSWORD=CHANGEME

# ============================================================
# Cache Configuration
# ============================================================
# ⚠️  CRITICAL: Load from GCP Secret Manager
REDIS_URL=redis://:CHANGEME@prod-ollama-redis:6379/0
REDIS_PASSWORD=CHANGEME

# ============================================================
# Vector Database Configuration
# ============================================================
QDRANT_URL=http://prod-ollama-qdrant:6333
QDRANT_COLLECTION_NAME=ollama_documents

# ============================================================
# API Configuration
# ============================================================
# GCP Load Balancer endpoint
PUBLIC_API_ENDPOINT=https://elevatediq.ai/ollama
API_KEY_AUTH_ENABLED=true

# ============================================================
# Firebase OAuth (if enabled)
# ============================================================
FIREBASE_ENABLED=false
FIREBASE_CREDENTIALS_PATH=/run/secrets/firebase_credentials

# ============================================================
# GCP Configuration (Secret Manager)
# ============================================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ============================================================
# GPU Configuration
# ============================================================
CUDA_VISIBLE_DEVICES=0
TF_CPP_MIN_LOG_LEVEL=2

# ============================================================
# Monitoring & Observability
# ============================================================
PROMETHEUS_ENABLED=true
JAEGER_ENABLED=true
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# ============================================================
# Performance Tuning
# ============================================================
# Connection pool sizes
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
REDIS_POOL_SIZE=10

# ============================================================
# DO NOT MODIFY BELOW FOR PRODUCTION
# ============================================================
DEVELOPMENT_MODE=false
SKIP_MIGRATIONS=false
